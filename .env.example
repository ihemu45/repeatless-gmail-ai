# ============================================================================
#  Repeatless Gmail AI — Environment Variables
#  Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.
# ============================================================================

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
# The public base URL of the app. Locally this is http://localhost:3000.
# In production set it to your Vercel URL (e.g. https://your-app.vercel.app).
APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Google OAuth 2.0 + Gmail API
# Create an OAuth client (type: Web application) in Google Cloud Console.
# Enable the "Gmail API". Add the authorized redirect URI:
#   <APP_URL>/api/auth/callback   (e.g. http://localhost:3000/api/auth/callback)
# See SETUP.md for the full step-by-step.
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ----------------------------------------------------------------------------
# Supabase (Postgres + pgvector)
# Project Settings → API. The service-role key is SERVER-ONLY (full DB access);
# never expose it to the browser.
# ----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: anon key (only needed if you add client-side Supabase calls later).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ----------------------------------------------------------------------------
# Google Gemini API (PRIMARY AI MODEL — required by the assignment)
# Get a key from https://aistudio.google.com/apikey
# ----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
# Generation model used for summaries, drafting and the chat agent.
GEMINI_MODEL=gemini-2.0-flash
# Embedding model used to build the pgvector index (768 dimensions).
GEMINI_EMBED_MODEL=text-embedding-004

# ----------------------------------------------------------------------------
# NVIDIA NIM (SECONDARY AI MODEL — required by the assignment)
# OpenAI-compatible endpoint. Get a free key from https://build.nvidia.com
# Used for fast email categorization and RAG re-ranking.
# ----------------------------------------------------------------------------
NVIDIA_NIM_API_KEY=your-nvidia-nim-api-key
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.1-8b-instruct

# ----------------------------------------------------------------------------
# Security
# Generate strong random values:  openssl rand -base64 32
# ----------------------------------------------------------------------------
# Signs the session cookie (JWT, HS256).
SESSION_SECRET=generate-a-32+-byte-random-string
# Encrypts Google refresh tokens at rest (AES-256-GCM). MUST be 32 bytes,
# base64-encoded:  openssl rand -base64 32
ENCRYPTION_KEY=generate-a-32-byte-base64-key

# ----------------------------------------------------------------------------
# Background sync
# Protects the Vercel Cron sync endpoint. Vercel sends this automatically as a
# Bearer token when you configure CRON_SECRET in project env vars.
# ----------------------------------------------------------------------------
CRON_SECRET=generate-a-random-string
